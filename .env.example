# Converge canvas — Collab (Google Gemini, server-only; never sent to the browser).
# Create a key at https://aistudio.google.com/apikey — optional GEMINI_COLLAB_MODEL override.
# GEMINI_API_KEY=
# Optional alias (same value as GEMINI_API_KEY):
# GOOGLE_API_KEY=
# Lowercase alias (if your shell/.env uses it):
# gemini_api_key=
# GEMINI_COLLAB_MODEL=gemini-2.5-flash

# Converge brand aesthetic (optional). Defaults: server/canvas/data/convergeBrandContext.json
# CONVERGE_BRAND_CONTEXT_PATH=
# Set to bmw_explicit to use *Explicit* strings in that JSON (stronger BMW wording in prompts).
# CONVERGE_BRAND_PROMPT_MODE=

EXTRACTION_PROVIDER=comfyui
# EXTRACTION_PROVIDER=mock
# Set to true only if you explicitly want mock results when ComfyUI fails.
COMFYUI_ALLOW_MOCK_FALLBACK=false

# Public app origin (optional). Does NOT redirect localhost unless you also set VITE_REDIRECT_LOCAL_TO_PUBLIC.
# Production (netailab.com / VPS + Cloudflare Tunnel): see docs/netailab.com.md
# VITE_PUBLIC_APP_ORIGIN=https://netailab.com
# Use for documentation or to match your tunnel/deploy hostname; local /api/* works either way.
# VITE_PUBLIC_APP_ORIGIN=https://example.com
# Set true only if you want localhost/127.0.0.1 tabs to jump to VITE_PUBLIC_APP_ORIGIN (e.g. parity test).
# Otherwise leave unset so Curate on http://localhost:5174 stays local. ?local=1 still bypasses when enabled.
# VITE_REDIRECT_LOCAL_TO_PUBLIC=true

# Phone capture QR / copy link base (optional). If you use http://localhost:5174 on desktop, the QR would encode
# localhost — Safari on your phone cannot reach your Mac. Set to your machine's LAN URL with the same port, e.g.:
# VITE_PHONE_CAPTURE_ORIGIN=http://192.168.1.10:5174
# Or open the app via that LAN URL in the browser so window.location.origin is already reachable from the phone.
# Production (https://netailab.com) does not need this.

# Live tunnel (optional)
# CLOUDFLARE_TUNNEL_TOKEN=
# CLOUDFLARE_PUBLIC_HOSTNAME=

# Optional API hardening for public deployments:
# Set a shared secret and pass it as x-api-key (or Authorization: Bearer <key>) to protected /api routes.
# Health/config endpoints remain public for uptime checks.
# API_SHARED_KEY=
# API_RATE_LIMIT_PER_MINUTE=120
# API_RATE_LIMIT_WINDOW_MS=60000

# Optional persistence for in-memory demo state (live capture sessions + extraction jobs)
# Writes JSON snapshots under this directory relative to repo root.
# SERVER_STATE_DIR=.runtime

# Required when EXTRACTION_PROVIDER=comfyui (HTTP 502 = nothing reachable at this URL or bad gateway).
# This file defaults to local Comfy; your real .env may use https://cloud.comfy.org instead — both are valid.
COMFYUI_BASE_URL=http://127.0.0.1:8188
# Must match the checkpoint node in your workflow JSON (default app workflow is SD1.5 sculptural 3-way).
# Must match a file in ComfyUI models/checkpoints (e.g. dreamshaper_8PrunedFp16.safetensors if you use the pruned build)
COMFYUI_CHECKPOINT_NAME=dreamshaper_8.safetensors
# Converge Stylize img2img: denoise strength (0.35–0.95). Lower stays closer to input and reduces squashed/warped geometry; default in code is 0.58 if unset.
# COMFYUI_CANVAS_STYLIZE_DENOISE_IMAGE=0.58

# Comfy Cloud (pick local COMFYUI_BASE_URL above OR this block — not both active unless you know why):
# COMFYUI_BASE_URL=https://cloud.comfy.org
# COMFYUI_API_KEY=your-comfy-cloud-api-key
# Same as COMFYUI_API_KEY; supported for convenience:
# COMFY_CLOUD_API_KEY=your-comfy-cloud-api-key
# Set true if COMFYUI_BASE_URL is not https://cloud.comfy.org but still uses Comfy Cloud API paths + auth:
# COMFYUI_CLOUD_MODE=true

# Optional output resolver if your browser cannot access COMFYUI_BASE_URL directly
# COMFYUI_OUTPUT_BASE_URL=http://127.0.0.1:8188

# Workflow JSON: the app loads comfy/workflows/<constraintSettings.workflowFile> first (Curate preset).
# Design language → sculptural_essence_3way_api.json, Experience → interior_uxui_3way_api.json, etc.
# COMFYUI_WORKFLOW_JSON / COMFYUI_WORKFLOW_PATH are used only if that file is missing, or set:
# COMFYUI_FORCE_ENV_WORKFLOW=true to force env overrides before preset files.
# COMFYUI_WORKFLOW_PATH=/absolute/path/to/your/api-workflow.json
# COMFYUI_WORKFLOW_JSON={"4":{"class_type":"CheckpointLoaderSimple","inputs":{"ckpt_name":"..."}}}

# Optional node mapping overrides for workflow injection
# COMFYUI_IMAGE_NODE_ID=5
# COMFYUI_IMAGE_NODE_INPUT_KEY=image
# COMFYUI_PROMPT_NODE_ID=6
# COMFYUI_PROMPT_NODE_INPUT_KEY=text
# COMFYUI_PROMPT_NODE_IDS=4,5,6
# COMFYUI_NEGATIVE_PROMPT_NODE_ID=7
# COMFYUI_NEGATIVE_PROMPT_NODE_INPUT_KEY=text
# COMFYUI_NEGATIVE_PROMPT_NODE_IDS=7
# COMFYUI_CHECKPOINT_NODE_ID=4
# COMFYUI_CHECKPOINT_NODE_INPUT_KEY=ckpt_name
# COMFYUI_SAMPLER_NODE_ID=6
# COMFYUI_SAMPLER_SEED_INPUT_KEY=seed
# COMFYUI_SAMPLER_NODE_IDS=8,9,10
# COMFYUI_SAVE_IMAGE_NODE_ID=8
# COMFYUI_SAVE_IMAGE_PREFIX_INPUT_KEY=filename_prefix
# COMFYUI_SAVE_IMAGE_NODE_IDS=14,15,16
# COMFYUI_OUTPUT_NODE_ID=8
# COMFYUI_OUTPUT_NODE_IDS=14,15,16

# Optional explicit extraction-mode injection node
# COMFYUI_MODE_NODE_ID=
# COMFYUI_MODE_NODE_INPUT_KEY=text

# Optional prompt and polling configuration
# COMFYUI_NEGATIVE_PROMPT=text, watermark, logo, typography, low quality, duplicate
# Post-decode upscale factor for ImageScaleBy nodes in bundled workflows (default 2 in JSON; set 1 to disable)
# COMFYUI_IMAGE_SCALE_BY=2
# Keep workflow JSON CLIP text as-is (otherwise interior_uxui_3way already preserves embedded prompts automatically)
# COMFYUI_EMBEDDED_PROMPTS_ONLY=true
# COMFYUI_POLL_INTERVAL_MS=1500
# COMFYUI_POLL_TIMEOUT_MS=120000
# COMFYUI_DEBUG=true

# Converge Stylize (Comfy img2img when EXTRACTION_PROVIDER=comfyui and COMFYUI_BASE_URL are set).
# Uses comfy/workflows/extract-image-api.json by default; override path or basename if needed.
# COMFYUI_CANVAS_STYLIZE_WORKFLOW_PATH=/absolute/path/to/workflow-api.json
# COMFYUI_CANVAS_STYLIZE_WORKFLOW=extract-image-api.json
# COMFYUI_CANVAS_STYLIZE_TIMEOUT_MS=120000
# COMFYUI_CANVAS_STYLIZE_OUTPUT_NODE_ID=8
